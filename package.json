{
  "name": "@gaberrb/polypus",
  "version": "0.6.9",
  "description": "Agentic coding harness that makes any AI API (with or without native tool-calling) generate and apply code. OpenRouter, Ollama, and any OpenAI-compatible endpoint.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/vscode"
  ],
  "bin": {
    "polypus": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./lib": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "context": "node scripts/update-context.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "openrouter",
    "ollama",
    "llm",
    "cli",
    "harness"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "Gabriel Rios (https://github.com/GaberRB)",
  "homepage": "https://github.com/GaberRB/polypus#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GaberRB/polypus.git"
  },
  "bugs": {
    "url": "https://github.com/GaberRB/polypus/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.1.0",
    "openai": "^4.67.0",
    "picocolors": "^1.1.0",
    "simple-git": "^3.27.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
