{
  "name": "polypus-vscode",
  "displayName": "Polypus — agentic AI chat",
  "description": "Chat agêntico no VSCode com a sua chave e modelos grátis/baratos (OpenRouter). Sem assinatura.",
  "version": "0.5.24",
  "private": true,
  "publisher": "gaberrb",
  "author": "Gabriel Rios",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GaberRB/polypus.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["AI", "Chat", "Machine Learning", "Programming Languages"],
  "keywords": ["ai", "agent", "openrouter", "chat", "coding assistant", "copilot alternative"],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "polypus",
          "title": "Polypus",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "polypus": [
        {
          "id": "polypus.chat",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "polypus.customProvider",
          "name": "Provedores & Chaves",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "polypus.focusChat",
        "title": "Polypus: Abrir chat"
      },
      {
        "command": "polypus.setApiKey",
        "title": "Polypus: Configurar chave do OpenRouter"
      },
      {
        "command": "polypus.addCustomProvider",
        "title": "Polypus: Adicionar provedor custom"
      },
      {
        "command": "polypus.clearApiKey",
        "title": "Polypus: Remover chave do OpenRouter"
      }
    ],
    "keybindings": [
      {
        "command": "polypus.focusChat",
        "key": "ctrl+escape",
        "mac": "cmd+escape"
      }
    ],
    "configuration": {
      "title": "Polypus",
      "properties": {
        "polypus.cliPath": {
          "type": "string",
          "default": "",
          "description": "Caminho para um CLI polypus externo. Vazio = usa o CLI empacotado na extensão."
        },
        "polypus.mode": {
          "type": "string",
          "enum": ["review", "plan", "bypass"],
          "default": "review",
          "description": "Modo de permissão das execuções."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package --no-dependencies",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@gaberrb/polypus-chat-ui": "*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
